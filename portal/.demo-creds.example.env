# Real-mode demo credentials — COPY to ~/okta-demo-creds.env and fill in.
# This example file is safe to commit; the real one (~/okta-demo-creds.env) is gitignored.
# Loaded by portal/src/config.mjs when DEMO_MODE=real. Never commit real values.

# ── Hub org (the IdP; hosts the portal OIDC app + Division Leads group) ──
HUB_ORG_DOMAIN=https://velocity27-hub-admin.oktapreview.com
HUB_API_TOKEN=SSWS 0017zVOeetpfeLkXMvRiWgaf4f6G-Dqb2vdNPAxZIb       # admin token: create app/group, assign users, config SAML IdP

# ── Portal OIDC app on the hub (Phase 1: real login) ──
# Leave CLIENT_ID/SECRET blank and I'll create the OIDC app via HUB_API_TOKEN,
# or paste an existing app's values here.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/callback
# Exact group name that gates provisioning (must exist / I'll create it):
REQUIRED_GROUP=Division Leads

# ── Pool of real blank spoke orgs (Phase 2/3). Comma-separated, paired by index. ──
# Each spoke needs an admin token to apply the baseline (Phase 2) and configure
# inbound SAML SP + the Org2Org app (Phase 3).
SPOKE_ORG_DOMAINS=velocity27-spoke1.oktapreview.com,velocity27-spoke2.oktapreview.com
SPOKE_API_TOKENS=SSWS_00gHnBWM_lsSKRqND7eVGkOSruwneNfaBQn-Q5cIZW,SSWS_00icLuhH6GO0q6G5U_cgdEoUNg64dtAZg4IYt7hwFV
