# Real-mode demo credentials — COPY to ~/okta-demo-creds.env and fill in.
# DO NOT put real values in THIS file — it is tracked in git. The real one
# (~/okta-demo-creds.env) is gitignored. Loaded by portal/src/config.mjs when
# DEMO_MODE=real.

# ── Hub org (the IdP; hosts the portal OIDC app + Division Leads group) ──
# Use the BASE org domain, no https://, no -admin (e.g. velocity27-hub.oktapreview.com)
HUB_ORG_DOMAIN=your-hub.oktapreview.com
HUB_API_TOKEN=                                  # admin SSWS token (value only, no inline comment)

# ── Portal OIDC app on the hub (Phase 1: real login) ──
# Leave CLIENT_ID/SECRET blank and I'll create the OIDC app via HUB_API_TOKEN.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/callback
REQUIRED_GROUP=Division Leads

# ── Pool of real blank spoke orgs (Phase 2/3). Comma-separated, paired by index. ──
SPOKE_ORG_DOMAINS=spoke1.oktapreview.com,spoke2.oktapreview.com
SPOKE_API_TOKENS=
